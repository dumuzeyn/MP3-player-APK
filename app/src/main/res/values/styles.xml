<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowBackground">#FFFFFF</item>
    </style>
    <style name="AppTheme.Dark" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowBackground">#000000</item>
    </style>
    <style name="AppThemeCustomBlueLight" parent="AppTheme" />
    <style name="AppThemeCustomBlueDark" parent="AppTheme.Dark" />
    <style name="AppThemeCustomRedLight" parent="AppTheme" />
    <style name="AppThemeCustomRedDark" parent="AppTheme.Dark" />
    <style name="AppThemeCustomGreenLight" parent="AppTheme" />
    <style name="AppThemeCustomGreenDark" parent="AppTheme.Dark" />
    <style name="AppThemeCustomPinkLight" parent="AppTheme" />
    <style name="AppThemeCustomPinkDark" parent="AppTheme.Dark" />
    <style name="AppThemeCustomOrangeLight" parent="AppTheme" />
    <style name="AppThemeCustomOrangeDark" parent="AppTheme.Dark" />
</resources>

